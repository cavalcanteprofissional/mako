<svg width="400" height="300" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="400" height="300" fill="#f0f4f8"/>
  
  <!-- Painel Placeholder -->
  <rect x="50" y="50" width="300" height="200" fill="#0056A8"/>
  <rect x="70" y="70" width="260" height="160" fill="#333"/>
  
  <!-- Displays -->
  <rect x="90" y="90" width="100" height="80" fill="#1a1a1a"/>
  <rect x="210" y="90" width="100" height="80" fill="#1a1a1a"/>
  
  <!-- LEDs -->
  <circle cx="140" cy="130" r="5" fill="#00ff00"/>
  <circle cx="160" cy="130" r="5" fill="#00ff00"/>
  <circle cx="140" cy="150" r="5" fill="#ffff00"/>
  <circle cx="160" cy="150" r="5" fill="#ff0000"/>
  
  <circle cx="260" cy="130" r="5" fill="#00ff00"/>
  <circle cx="280" cy="130" r="5" fill="#00ff00"/>
  <circle cx="260" cy="150" r="5" fill="#ffff00"/>
  <circle cx="280" cy="150" r="5" fill="#ff0000"/>
  
  <!-- Botões -->
  <rect x="120" y="180" width="60" height="30" fill="#666"/>
  <rect x="220" y="180" width="60" height="30" fill="#666"/>
  
  <!-- Texto -->
  <text x="200" y="270" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#333" text-anchor="middle">Painel de Controle</text>
</svg>