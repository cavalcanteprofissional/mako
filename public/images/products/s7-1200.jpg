<svg width="400" height="300" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="400" height="300" fill="#f0f4f8"/>
  
  <!-- CLP Placeholder -->
  <rect x="50" y="100" width="300" height="100" rx="10" fill="#0056A8"/>
  <rect x="70" y="120" width="40" height="20" fill="#ffffff"/>
  <rect x="130" y="120" width="40" height="20" fill="#ffffff"/>
  <rect x="190" y="120" width="40" height="20" fill="#ffffff"/>
  <rect x="250" y="120" width="40" height="20" fill="#ffffff"/>
  
  <!-- LEDs -->
  <circle cx="80" cy="160" r="5" fill="#00ff00"/>
  <circle cx="100" cy="160" r="5" fill="#00ff00"/>
  <circle cx="120" cy="160" r="5" fill="#ffff00"/>
  <circle cx="140" cy="160" r="5" fill="#ff0000"/>
  
  <!-- Display -->
  <rect x="200" y="150" width="120" height="40" fill="#1a1a1a"/>
  <text x="260" y="175" font-family="monospace" font-size="12" fill="#00ff00" text-anchor="middle">SIEMENS</text>
  
  <!-- Texto -->
  <text x="200" y="250" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#333" text-anchor="middle">CLP Siemens S7-1200</text>
</svg>