<svg width="400" height="300" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="400" height="300" fill="#f0f4f8"/>
  
  <!-- Software Placeholder -->
  <rect x="50" y="50" width="300" height="200" fill="#1a1a1a" stroke="#0056A8" stroke-width="3"/>
  
  <!-- Título da janela -->
  <rect x="50" y="50" width="300" height="30" fill="#0056A8"/>
  <text x="200" y="70" font-family="Arial, sans-serif" font-size="14" fill="white" text-anchor="middle">SCADA System v2.0</text>
  
  <!-- Menu lateral -->
  <rect x="60" y="90" width="80" height="150" fill="#333"/>
  <rect x="70" y="100" width="60" height="20" fill="#0056A8"/>
  <rect x="70" y="130" width="60" height="20" fill="#666"/>
  <rect x="70" y="160" width="60" height="20" fill="#666"/>
  <rect x="70" y="190" width="60" height="20" fill="#666"/>
  
  <!-- Área principal -->
  <rect x="150" y="90" width="190" height="150" fill="#2a2a2a"/>
  
  <!-- Gráficos -->
  <rect x="160" y="100" width="80" height="60" fill="#444"/>
  <path d="M170 150 L 180 130 L 190 140 L 200 120 L 210 130 L 220 125 L 230 130" stroke="#00ff00" stroke-width="2" fill="none"/>
  
  <rect x="250" y="100" width="80" height="60" fill="#444"/>
  <circle cx="290" cy="130" r="20" fill="none" stroke="#ff6b00" stroke-width="2"/>
  <path d="M290 110 L 290 130 L 305 130" stroke="#ff6b00" stroke-width="2" fill="none"/>
  
  <!-- Status indicators -->
  <rect x="160" y="170" width="170" height="60" fill="#333"/>
  <text x="245" y="195" font-family="monospace" font-size="12" fill="#00ff00" text-anchor="middle">SYSTEM ONLINE</text>
  <text x="245" y="215" font-family="monospace" font-size="10" fill="#00ff00" text-anchor="middle">All Systems Operational</text>
  
  <!-- Texto -->
  <text x="200" y="270" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#333" text-anchor="middle">Software SCADA</text>
</svg>