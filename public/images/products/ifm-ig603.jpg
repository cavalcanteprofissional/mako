<svg width="400" height="300" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="400" height="300" fill="#f0f4f8"/>
  
  <!-- Sensor Placeholder -->
  <circle cx="200" cy="150" r="60" fill="#FF6B00"/>
  <circle cx="200" cy="150" r="40" fill="#cc5500"/>
  <circle cx="200" cy="150" r="20" fill="#1a1a1a"/>
  
  <!-- Conector -->
  <rect x="180" y="210" width="40" height="30" fill="#666"/>
  <circle cx="200" cy="225" r="8" fill="#333"/>
  
  <!-- LED indicador -->
  <circle cx="200" cy="150" r="5" fill="#00ff00"/>
  
  <!-- Linhas de campo -->
  <circle cx="200" cy="150" r="80" fill="none" stroke="#0056A8" stroke-width="2" stroke-dasharray="5,5" opacity="0.5"/>
  <circle cx="200" cy="150" r="100" fill="none" stroke="#0056A8" stroke-width="2" stroke-dasharray="5,5" opacity="0.3"/>
  
  <!-- Texto -->
  <text x="200" y="270" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#333" text-anchor="middle">Sensor IFM IG603</text>
</svg>