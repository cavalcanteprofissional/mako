<svg width="400" height="300" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="400" height="300" fill="#f0f4f8"/>
  
  <!-- Cilindro Placeholder -->
  <rect x="150" y="50" width="100" height="200" fill="#666"/>
  <rect x="140" y="60" width="120" height="180" fill="#888"/>
  
  <!-- Haste do cilindro -->
  <rect x="175" y="180" width="50" height="60" fill="#ccc"/>
  <circle cx="200" cy="240" r="25" fill="#999"/>
  
  <!-- Conexões pneumáticas -->
  <rect x="130" y="100" width="20" height="15" fill="#ff6b00"/>
  <rect x="130" y="130" width="20" height="15" fill="#0056a8"/>
  
  <!-- Detalhes -->
  <line x1="150" y1="80" x2="250" y2="80" stroke="#333" stroke-width="2"/>
  <line x1="150" y1="230" x2="250" y2="230" stroke="#333" stroke-width="2"/>
  
  <!-- Texto -->
  <text x="200" y="280" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#333" text-anchor="middle">Atuador FESTO DFP</text>
</svg>