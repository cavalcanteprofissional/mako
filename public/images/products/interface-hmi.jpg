<svg width="400" height="300" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="400" height="300" fill="#f0f4f8"/>
  
  <!-- Interface Placeholder -->
  <rect x="50" y="50" width="300" height="200" fill="#444"/>
  <rect x="60" y="60" width="280" height="180" fill="#222"/>
  
  <!-- Display screen -->
  <rect x="80" y="80" width="240" height="120" fill="#001122"/>
  
  <!-- Grid lines -->
  <path d="M80 120 L 320 120 M 200 80 L 200 200" stroke="#003366" stroke-width="1" opacity="0.5"/>
  <path d="M140 80 L 140 200 M 260 80 L 260 200" stroke="#003366" stroke-width="1" opacity="0.5"/>
  <path d="M80 160 L 320 160" stroke="#003366" stroke-width="1" opacity="0.5"/>
  
  <!-- Data visualization -->
  <rect x="100" y="100" width="20" height="80" fill="#00ff00" opacity="0.7"/>
  <rect x="130" y="120" width="20" height="60" fill="#00ff00" opacity="0.7"/>
  <rect x="160" y="110" width="20" height="70" fill="#00ff00" opacity="0.7"/>
  <rect x="190" y="90" width="20" height="90" fill="#ffff00" opacity="0.7"/>
  <rect x="220" y="130" width="20" height="50" fill="#00ff00" opacity="0.7"/>
  <rect x="250" y="115" width="20" height="65" fill="#00ff00" opacity="0.7"/>
  <rect x="280" y="125" width="20" height="55" fill="#00ff00" opacity="0.7"/>
  
  <!-- Status indicators -->
  <circle cx="90" cy="90" r="3" fill="#00ff00"/>
  <circle cx="310" cy="90" r="3" fill="#00ff00"/>
  <circle cx="90" cy="190" r="3" fill="#00ff00"/>
  <circle cx="310" cy="190" r="3" fill="#00ff00"/>
  
  <!-- Control buttons -->
  <rect x="120" y="210" width="40" height="20" fill="#666"/>
  <rect x="180" y="210" width="40" height="20" fill="#666"/>
  <rect x="240" y="210" width="40" height="20" fill="#666"/>
  
  <!-- LEDs -->
  <circle cx="140" cy="220" r="3" fill="#00ff00"/>
  <circle cx="200" cy="220" r="3" fill="#ffff00"/>
  <circle cx="260" cy="220" r="3" fill="#ff0000"/>
  
  <!-- Texto -->
  <text x="200" y="270" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#333" text-anchor="middle">Interface HMI</text>
</svg>