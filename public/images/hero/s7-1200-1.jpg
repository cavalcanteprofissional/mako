<svg width="1920" height="1080" viewBox="0 0 1920 1080" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="1920" height="1080" fill="#f0f4f8"/>
  
  <!-- Industrial background pattern -->
  <g opacity="0.1">
    <defs>
      <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
        <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#0056A8" stroke-width="1"/>
      </pattern>
    </defs>
    <rect width="1920" height="1080" fill="url(#grid)"/>
  </g>
  
  <!-- Hero image placeholder content -->
  <g>
    <!-- Industrial equipment silhouette -->
    <rect x="100" y="400" width="300" height="280" fill="#0056A8" opacity="0.3"/>
    <rect x="450" y="350" width="250" height="330" fill="#FF6B00" opacity="0.3"/>
    <rect x="750" y="380" width="350" height="300" fill="#0056A8" opacity="0.3"/>
    
    <!-- Control panels -->
    <rect x="1200" y="300" width="400" height="250" fill="#666" opacity="0.2"/>
    <rect x="1250" y="350" width="300" height="150" fill="#333" opacity="0.3"/>
    
    <!-- Industrial elements -->
    <circle cx="300" cy="540" r="40" fill="#FF6B00" opacity="0.4"/>
    <circle cx="575" cy="515" r="30" fill="#0056A8" opacity="0.4"/>
    <circle cx="925" cy="530" r="35" fill="#FF6B00" opacity="0.4"/>
  </g>
  
  <!-- Central focus area -->
  <g>
    <rect x="760" y="440" width="400" height="200" fill="white" stroke="#0056A8" stroke-width="2"/>
    <text x="960" y="540" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#0056A8" text-anchor="middle">Automação Industrial</text>
    <text x="960" y="570" font-family="Arial, sans-serif" font-size="16" fill="#333" text-anchor="middle">Soluções Inteligentes</text>
  </g>
</svg>