<svg width="1920" height="1080" viewBox="0 0 1920 1080" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Gradiente industrial -->
  <defs>
    <linearGradient id="heroGrad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0056A8;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#003d7a;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="1920" height="1080" fill="url(#heroGrad1)"/>
  
  <!-- Elementos industriais estilizados -->
  <g opacity="0.3">
    <!-- Engrenagens -->
    <circle cx="200" cy="200" r="80" fill="none" stroke="white" stroke-width="2"/>
    <circle cx="200" cy="200" r="60" fill="none" stroke="white" stroke-width="2"/>
    <circle cx="200" cy="200" r="40" fill="none" stroke="white" stroke-width="2"/>
    
    <!-- Linhas de circuito -->
    <path d="M400 100 L 600 100 L 600 300 L 800 300" stroke="white" stroke-width="2"/>
    <path d="M400 150 L 500 150 L 500 350 L 850 350" stroke="white" stroke-width="2"/>
    <circle cx="400" cy="100" r="5" fill="white"/>
    <circle cx="600" cy="100" r="5" fill="white"/>
    <circle cx="600" cy="300" r="5" fill="white"/>
    <circle cx="800" cy="300" r="5" fill="white"/>
    
    <!-- Elementos automação -->
    <rect x="1200" y="400" width="200" height="100" fill="none" stroke="white" stroke-width="2"/>
    <rect x="1250" y="450" width="100" height="50" fill="none" stroke="white" stroke-width="2"/>
    <circle cx="1300" cy="475" r="20" fill="none" stroke="white" stroke-width="2"/>
  </g>
  
  <!-- Texto sobreposição -->
  <text x="960" y="540" font-family="Arial, sans-serif" font-size="48" font-weight="bold" fill="white" text-anchor="middle">Soluções em Automação Industrial</text>
  <text x="960" y="590" font-family="Arial, sans-serif" font-size="24" fill="white" text-anchor="middle">Tecnologia, eficiência e confiabilidade</text>
</svg>