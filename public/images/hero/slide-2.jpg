<svg width="1920" height="1080" viewBox="0 0 1920 1080" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Gradiente manutenção -->
  <defs>
    <linearGradient id="heroGrad2" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FF6B00;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#cc5500;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="1920" height="1080" fill="url(#heroGrad2)"/>
  
  <!-- Elementos manutenção estilizados -->
  <g opacity="0.3">
    <!-- Ferramentas -->
    <path d="M300 300 L 350 250 L 400 300 L 400 350 L 350 400 L 300 350 Z" fill="white"/>
    <path d="M320 320 L 380 320 M 350 290 L 350 410" stroke="#FF6B00" stroke-width="3"/>
    
    <!-- Medidores -->
    <circle cx="800" cy="300" r="100" fill="none" stroke="white" stroke-width="4"/>
    <path d="M800 300 L 850 250" stroke="white" stroke-width="4"/>
    <circle cx="800" cy="300" r="10" fill="white"/>
    
    <!-- Painel de controle -->
    <rect x="1200" y="200" width="300" height="400" fill="none" stroke="white" stroke-width="3"/>
    <rect x="1250" y="250" width="200" height="60" fill="none" stroke="white" stroke-width="2"/>
    <rect x="1250" y="330" width="200" height="60" fill="none" stroke="white" stroke-width="2"/>
    <rect x="1250" y="410" width="200" height="60" fill="none" stroke="white" stroke-width="2"/>
    
    <!-- LEDs -->
    <circle cx="1270" cy="280" r="10" fill="#00ff00"/>
    <circle cx="1300" cy="280" r="10" fill="#00ff00"/>
    <circle cx="1330" cy="280" r="10" fill="#ffff00"/>
    <circle cx="1360" cy="280" r="10" fill="#ff0000"/>
  </g>
  
  <!-- Texto sobreposição -->
  <text x="960" y="540" font-family="Arial, sans-serif" font-size="48" font-weight="bold" fill="white" text-anchor="middle">Manutenção Industrial Especializada</text>
  <text x="960" y="590" font-family="Arial, sans-serif" font-size="24" fill="white" text-anchor="middle">Máxima disponibilidade para seus equipamentos</text>
</svg>