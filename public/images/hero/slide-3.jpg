<svg width="1920" height="1080" viewBox="0 0 1920 1080" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Gradiente projetos -->
  <defs>
    <linearGradient id="heroGrad3" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0056A8;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#FF6B00;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0056A8;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="1920" height="1080" fill="url(#heroGrad3)"/>
  
  <!-- Elementos projetos estilizados -->
  <g opacity="0.3">
    <!-- Blueprint/Croqui -->
    <rect x="200" y="150" width="400" height="300" fill="none" stroke="white" stroke-width="2"/>
    <path d="M250 200 L 350 200 L 350 300 L 250 300 Z" fill="none" stroke="white" stroke-width="1"/>
    <path d="M450 200 L 550 200 L 550 300 L 450 300 Z" fill="none" stroke="white" stroke-width="1"/>
    
    <!-- Linhas de dimensão -->
    <path d="M250 200 L 250 180 L 350 180 L 350 200" stroke="white" stroke-width="1"/>
    <path d="M350 200 L 370 200" stroke="white" stroke-width="1"/>
    
    <!-- Gráfico de Gantt -->
    <rect x="800" y="200" width="600" height="400" fill="none" stroke="white" stroke-width="2"/>
    <rect x="820" y="250" width="150" height="40" fill="white"/>
    <rect x="820" y="310" width="200" height="40" fill="white"/>
    <rect x="820" y="370" width="120" height="40" fill="white"/>
    <rect x="820" y="430" width="180" height="40" fill="white"/>
    
    <!-- Timeline -->
    <path d="M820 520 L 1380 520" stroke="white" stroke-width="2"/>
    <circle cx="820" cy="520" r="5" fill="white"/>
    <circle cx="970" cy="520" r="5" fill="white"/>
    <circle cx="1120" cy="520" r="5" fill="white"/>
    <circle cx="1270" cy="520" r="5" fill="white"/>
    <circle cx="1380" cy="520" r="5" fill="white"/>
  </g>
  
  <!-- Texto sobreposição -->
  <text x="960" y="540" font-family="Arial, sans-serif" font-size="48" font-weight="bold" fill="white" text-anchor="middle">Projetos Sob Medida</text>
  <text x="960" y="590" font-family="Arial, sans-serif" font-size="24" fill="white" text-anchor="middle">Soluções personalizadas para seu negócio</text>
</svg>